  "runtime_introspection": {
    "dart_flutter_mcp": {
      "status": "supported_by_local_sdk",
      "minimum_dart": "3.9",
      "server_command": "dart mcp-server --force-roots-fallback",
      "codex_setup": "codex mcp add dart -- dart mcp-server --force-roots-fallback",
      "purpose": "symbols, tests, analyzer diagnostics, DTD and running Flutter widget/runtime state"
    },
    "tbls": {
      "status": "required_local_disposable_schema_gate",
      "config": ".tbls.yml",
      "command": "scripts/manaloom_local_ci.sh schema",
      "purpose": "apply repository DDL and migrations to an isolated loopback PostgreSQL, generate tbls Mermaid documentation, and compare tables, views, columns, foreign keys, and migration count with the manifest"
    },
    "local_gates": {
      "status": "required_no_remote_ci",
      "hooks": [".githooks/pre-commit", ".githooks/pre-push"],
      "commands": [
        "scripts/manaloom_local_ci.sh quick",
        "scripts/manaloom_local_ci.sh full",
        "scripts/manaloom_local_ci.sh e2e",
        "scripts/manaloom_local_ci.sh release"
      ],
      "policy": "GitHub Actions is intentionally absent; checks run on developer-owned local hardware without hosted-runner cost"
    }
  },
  "known_limits": [
    "Generated OpenAPI is structural: inline request/response Maps are not inferred as authoritative schemas.",
    "Resolved AST, call graph, type references, and SQL extraction cannot explain product intent, architectural reasons, accepted risk or rollout decisions.",
    "The repository ERD is checked against a freshly applied disposable PostgreSQL; a production database still requires its own read-only migration/status evidence.",
    "Flutter Web finder commands are not exposed by Flutter Driver; use DTD for runtime state and a browser tool for interaction.",
    "A green drift gate proves synchronization, not product correctness or production readiness."
  ]
}
