{
  "schema_version": "manaloom_external_engine_capabilities_v1_2026-07-22",
  "policy": {
    "product_source_of_truth": "postgresql_backend",
    "rules_execution_order": [
      "xmage",
      "forge",
      "native_explicit_residual"
    ],
    "card_level_learning_requires_typed_natural_event": true,
    "external_source_code_is_never_direct_postgresql_truth": true,
    "unclassified_capabilities_allowed": false,
    "local_source_checkout_policy": {
      "root_argument": "--xmage-root",
      "environment_fallback": "MANALOOM_XMAGE_SOURCE_ROOT",
      "requires_canonical_pin": true,
      "requires_clean_checkout": true,
      "forbid_machine_specific_defaults": true,
      "shared_resolver": "docs/hermes-analysis/manaloom-knowledge/scripts/external_engine_source_contract.py"
    }
  },
  "engines": [
    {
      "id": "xmage",
      "official_repository": "https://github.com/magefree/mage",
      "canonical_pin_file": "services/xmage-sidecar/XMAGE_COMMIT",
      "license": "MIT",
      "runtime_role": "primary_external_rules_executor",
      "integration_boundary": "isolated_sidecar_api",
      "allowed_java_root": "services/xmage-sidecar",
      "source_inventory_minimums": {
        "card_implementations": 30000,
        "java_tests": 1900
      }
    },
    {
      "id": "forge",
      "official_repository": "https://github.com/Card-Forge/forge",
      "canonical_pin_file": "services/forge-sidecar/FORGE_COMMIT",
      "license": "GPL-3.0-only",
      "runtime_role": "secondary_external_rules_executor_for_structured_xmage_gaps",
      "integration_boundary": "isolated_process_api_only_no_backend_source_copy",
      "allowed_java_root": "services/forge-sidecar",
      "source_inventory_minimums": {
        "card_scripts": 33000,
        "java_tests": 90
      }
    }
  ],
  "required_capability_ids": [
    "rules_execution",
    "catalog_coverage_preflight",
    "commander_multiplayer_execution",
    "priority_stack_sba_replacement",
    "engine_ai_action_selection",
    "timeout_process_isolation",
    "replay_event_normalization",
    "engine_provenance_and_pin_drift",
    "structured_xmage_gap_fallback",
    "exact_card_source_reference",
    "semantic_family_taxonomy",
    "upstream_scenario_corpus",
    "commander_legality_crosscheck",
    "deck_generation_and_relation_matrix",
    "ai_internal_search_and_decision_rationale",
    "commander_bracket_calculator",
    "draft_sealed_tournament_modes",
    "client_editor_network_and_adventure",
    "ratings_and_matchmaking",
    "source_code_copy_into_backend"
  ],
  "capabilities": [
    {
      "id": "rules_execution",
      "engines": ["xmage", "forge"],
      "relevance": "required",
      "disposition": "adopted_runtime",
      "source_surfaces": [
        "XMage Mage game/ability/card implementations",
        "Forge forge-game and card scripts"
      ],
      "rationale": "Use each pinned engine to execute its covered cards instead of reproducing tens of thousands of rules natively.",
      "product_evidence": [
        "services/xmage-sidecar/src/main/java/com/manaloom/xmage/XmageBattleService.java",
        "services/forge-sidecar/SeededForgeMain.java",
        "server/lib/ai/battle_engine_config.dart"
      ],
      "test_evidence": [
        "services/xmage-sidecar/src/test/java/com/manaloom/xmage/XmageBattleServiceTest.java",
        "services/forge-sidecar/test_sidecar.py",
        "server/test/battle_engine_config_test.dart"
      ]
    },
    {
      "id": "catalog_coverage_preflight",
