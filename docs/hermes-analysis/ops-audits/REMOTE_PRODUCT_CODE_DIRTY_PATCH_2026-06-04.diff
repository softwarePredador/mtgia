-        CASE
-          WHEN cl.status = 'legal' THEN 0
-          WHEN cl.status = 'restricted' THEN 1
-          WHEN cl.status IS NULL THEN 2
-          ELSE 3
-        END,
-        c.id::text
-    '''),
-    parameters: {
-      'names': TypedValue(
-        Type.textArray,
