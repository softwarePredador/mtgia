# ========================================
# MTG Deck Builder - Environment Variables
# ========================================
# 
# Este arquivo serve como template para configuração.
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha os valores reais no arquivo .env
# 3. NUNCA commite o arquivo .env (já está no .gitignore)

# Use `production` no deploy. A política CORS usa este valor para bloquear
# origens HTTP e loopback mesmo se forem incluídas por engano na allowlist.
ENVIRONMENT=development

# ========================================
# Database Configuration
# ========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mtgdb
DB_USER=postgres
DB_PASS=your_password_here
DB_SSL_MODE=disable
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/mtgdb?sslmode=disable
# O backend limita a idade das conexoes para nao reutilizar sockets expirados
# pela rede Docker. Estes valores sao opcionais e mostram os defaults.
DB_POOL_MAX_CONNECTIONS=10
DB_POOL_MAX_AGE_SECONDS=300
DB_CONNECT_TIMEOUT_SECONDS=8
DB_QUERY_TIMEOUT_SECONDS=60

# Battle rules execution. `auto` is the production default and requires both
# internal sidecars. Use `native` only as an explicit legacy/advisory mode.
BATTLE_ENGINE=auto
XMAGE_SIDECAR_URL=http://xmage-sidecar:8080
FORGE_SIDECAR_URL=http://forge-sidecar:8080
NATIVE_BATTLE_SIDECAR_URL=http://evolution_manaloom-ops:8080

# Coleta automatizada EDHREC é desabilitada por padrão. Habilite somente após
# autorização explícita para o ambiente e a finalidade de coleta.
MANALOOM_EDHREC_AUTOMATED_COLLECTION_AUTHORIZED=false

# Beta gratuita: billing é bloqueado em código, sem escape hatch por ambiente.
# Reativar compra exige adapter revisado, webhook idempotente e E2E de pagamento.

# CORS do backend. Em produção, liste origens web exatas separadas por vírgula.
# Clientes nativos não enviam Origin e continuam aceitos. Wildcard não é usado.
MANALOOM_ALLOWED_ORIGINS=
# Loopback (localhost/127.0.0.1/::1) só abre em development e com opt-in explícito.
MANALOOM_ALLOW_DEV_ORIGINS=false

# URL pública usada pelo backend ao criar links de /reports/:id.
# Ajustar quando domínio final estiver publicado.
MANALOOM_PUBLIC_SITE_URL=https://manaloom.com

# ========================================
# JWT Secret (OBRIGATÓRIO)
# ========================================
# Gere uma chave segura com:
#   openssl rand -base64 48
# O runtime exige no mínimo 32 caracteres/bytes em produção e recusa
# placeholders, marcadores de teste e segredos de baixa diversidade.
# 
# ⚠️ NUNCA use a mesma chave em dev e produção
# ⚠️ Se esta chave vazar, TODOS os tokens ficam comprometidos
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING

# ========================================
# OpenAI API (obrigatoria em producao)
# ========================================
# Necessário para funcionalidades de IA:
# - POST /ai/explain (explicação de cartas)
# - POST /ai/archetypes (sugestões de otimização)
# - POST /ai/generate (gerador de decks)
# 
# Em desenvolvimento, endpoints podem usar fallback determinístico. Em produção,
# ausência ou falha do provedor retorna erro explícito e nunca simula sucesso.
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Perfil de execução da IA (opcional): dev | staging | prod
# Se omitido, o sistema deriva de ENVIRONMENT. ENVIRONMENT=production sempre
# força prod, mesmo que OPENAI_PROFILE tenha sido configurado incorretamente.
OPENAI_PROFILE=dev

# Segredo exclusivo para métricas operacionais em /health/* (mínimo 32 chars).
# O deploy gera e mantém este valor apenas na spec remota quando ele não existe.
# Nunca use esta chave no app cliente ou em código versionado.
MANALOOM_OPS_API_KEY=

# Modelos por endpoint (opcionais)
OPENAI_MODEL_GENERATE=gpt-4o-mini
OPENAI_MODEL_ARCHETYPES=gpt-4o-mini
OPENAI_MODEL_EXPLAIN=gpt-4o-mini
OPENAI_MODEL_RECOMMENDATIONS=gpt-4o-mini
OPENAI_MODEL_AI_ANALYSIS=gpt-4o-mini
OPENAI_MODEL_OPTIMIZE=gpt-5.4-mini
OPENAI_MODEL_COMPLETE=gpt-5.4-mini
OPENAI_MODEL_OPTIMIZATION_CRITIC=gpt-4o-mini

# Temperaturas por endpoint (0.0 - 1.0, opcionais)
OPENAI_TEMP_GENERATE=0.4
OPENAI_TEMP_ARCHETYPES=0.3
OPENAI_TEMP_EXPLAIN=0.5
OPENAI_TEMP_RECOMMENDATIONS=0.3
OPENAI_TEMP_AI_ANALYSIS=0.2
OPENAI_TEMP_OPTIMIZE=0.3
OPENAI_TEMP_COMPLETE=0.3
OPENAI_TEMP_OPTIMIZATION_CRITIC=0.2

# Limites por chamada ao provedor (segundos, opcionais). O runtime aplica
# limites mínimos/máximos mesmo quando estes valores são sobrescritos.
OPENAI_TIMEOUT_GENERATE_SECONDS=20
OPENAI_TIMEOUT_GENERATE_REFERENCE_SECONDS=24
OPENAI_TIMEOUT_ARCHETYPES_SECONDS=20
OPENAI_TIMEOUT_EXPLAIN_SECONDS=20
OPENAI_TIMEOUT_RECOMMENDATIONS_SECONDS=20
OPENAI_TIMEOUT_AI_ANALYSIS_SECONDS=20
OPENAI_TIMEOUT_OPTIMIZE_SECONDS=30
OPENAI_TIMEOUT_COMPLETE_SECONDS=30
OPENAI_TIMEOUT_OPTIMIZATION_CRITIC_SECONDS=20

# Presets recomendados por ambiente:
# - dev: custo menor e iteração rápida (predominantemente gpt-4o-mini)
# - staging: comportamento próximo de produção com custo controlado
# - prod: otimização/complete em gpt-5.4-mini, demais em gpt-4o-mini

# ========================================
# Environment Mode
# ========================================
# Valores aceitos: development | production
# 
# Afeta:
# - SSL do banco (obrigatório em production)
# - Logs (mais verboso em development)
ENVIRONMENT=development
APP_VERSION=manaloom@local

# Ativa rate limiting distribuído (PostgreSQL) em produção.
# Em dev/test, o sistema mantém comportamento in-memory.
RATE_LIMIT_DISTRIBUTED=true

# Quantidade de saltos confiáveis na cadeia X-Forwarded-For, contados da
# direita para a esquerda. Obrigatório e maior que zero em produção. O proxy
# de borda deve remover/reescrever headers recebidos e acrescentar o IP real;
# o serviço backend não pode ficar diretamente acessível pela internet.
MANALOOM_TRUSTED_PROXY_HOPS=0
# IPs ou CIDRs dos peers que podem entregar X-Forwarded-For ao backend.
# Wildcards 0.0.0.0/0 e ::/0 são recusados. Exemplo local: 127.0.0.1/32.
MANALOOM_TRUSTED_PROXY_PEERS=

# ========================================
# Sentry / Observabilidade (OPCIONAL)
# ========================================
# Backend:
# - inicializa Sentry no middleware global
# - captura exceções não tratadas
# - correlaciona com x-request-id
#
# App Flutter:
# - usa os mesmos nomes via --dart-define no build/run
# - não lê este arquivo diretamente
#
# Variáveis esperadas no backend:
#   SENTRY_DSN
#   SENTRY_ENVIRONMENT
#   SENTRY_RELEASE
#   SENTRY_TRACES_SAMPLE_RATE
SENTRY_DSN=
SENTRY_MOBILE_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_ENABLE_LOGS=false
SENTRY_AUTH_TOKEN=
SENTRY_ORG_SLUG=
SENTRY_TEAM_SLUG=
SENTRY_BACKEND_PROJECT_SLUG=
SENTRY_MOBILE_PROJECT_SLUG=

# ========================================
# EasyPanel / Deploy Operacional (OPCIONAL)
# ========================================
# Placeholders para documentação e automação operacional.
# Não são lidos pelo backend hoje, mas formalizam o runbook de deploy.
# `API_BASE_URL`/`PUBLIC_API_BASE_URL` são usados pelos scripts de smoke
# operacional (`validate_request_id_ready.sh` e validações mobile).
API_BASE_URL=
PUBLIC_API_BASE_URL=
EASYPANEL_BASE_URL=
EASYPANEL_PROJECT_NAME=
EASYPANEL_APP_NAME=
EASYPANEL_DOMAIN=
EASYPANEL_AUTH_HEADER=Authorization
EASYPANEL_AUTH_SCHEME=Bearer
EASYPANEL_API_TOKEN=

# ManaLoom EasyPanel novo usado pelos scripts operacionais.
# Nao coloque segredos aqui; use caminho local da chave SSH ja provisionada.
MANALOOM_API_BASE_URL=https://evolution-cartinhas.2ta7qx.easypanel.host
MANALOOM_WEB_PUBLIC_URL=https://evolution-manaloom-web-public.2ta7qx.easypanel.host
MANALOOM_EASYPANEL_SSH_HOST=root@evolution-cartinhas.2ta7qx.easypanel.host
MANALOOM_EASYPANEL_SSH_KEY=~/.ssh/manaloom_easy_parallel_20260703
MANALOOM_POSTGRES_SERVICE=evolution_manaloom-postgres
MANALOOM_POSTGRES_USER=postgres
MANALOOM_POSTGRES_DB=halder
MANALOOM_BACKUP_DIR=./backups/manaloom-postgres
MANALOOM_RESTORE_MODE=schema
MANALOOM_RESTORE_POSTGRES_IMAGE=postgres:17.10-alpine3.23@sha256:8189a1f6e40904781fc9e2612687877791d21679866db58b1de996b31fc312e4

# Backup/restore remoto do Postgres no EasyPanel novo.
# Usado por `scripts/manaloom_install_remote_backup_cron.sh`.
MANALOOM_REMOTE_BACKUP_ROOT=/opt/manaloom
MANALOOM_REMOTE_BACKUP_DIR=/opt/manaloom/backups/postgres
MANALOOM_REMOTE_LOG_DIR=/opt/manaloom/logs
MANALOOM_BACKUP_RETENTION_DAYS=14
MANALOOM_BACKUP_CRON="17 2 * * *"
MANALOOM_RESTORE_CHECK_CRON="47 3 * * 0"
MANALOOM_RESTORE_VALIDATE_MODE=schema

# Quality gate comercial.
# Usado por `scripts/manaloom_commercial_quality_gate.sh`.
MANALOOM_AI_BENCHMARK_RUNS=3
MANALOOM_ALLOW_DEGRADED_AI=1
MANALOOM_QUALITY_GATE_OUT_DIR=./docs/qa/runtime

# ========================================
# Telemetry Admin (AI Optimize)
# ========================================
# IDs/e-mails com acesso às operações globais de IA, incluindo refresh de
# Commander Reference e escopo global de telemetria:
# GET /ai/optimize/telemetry?include_global=true
MANALOOM_ADMIN_USER_IDS=
MANALOOM_ADMIN_EMAILS=

# Aliases legados ainda aceitos durante a migração de ambientes existentes.
TELEMETRY_ADMIN_USER_IDS=
TELEMETRY_ADMIN_EMAILS=

# Retenção (dias) para limpeza de dados antigos da telemetria de optimize.
TELEMETRY_RETENTION_DAYS=180
# Logs de provedor e ações de IA não são mantidos indefinidamente.
AI_LOG_RETENTION_DAYS=180
# Jobs assíncronos são efêmeros; o resultado permanece só para o polling.
AI_JOB_RETENTION_MINUTES=30
# Reservas de cota interrompidas deixam de bloquear o usuário após este prazo.
# Deve permanecer maior que o maior timeout de execução de uma ação de IA.
AI_PLAN_RESERVATION_TTL_MINUTES=10
# Eventos distribuídos só sustentam janelas curtas; o daemon remove o histórico.
RATE_LIMIT_EVENT_RETENTION_HOURS=24

# ========================================
# ManaLoom Ops / Scheduler (OPCIONAL)
# ========================================
# Usado pelo serviço operacional server-owned que substitui os jobs Hermes
# críticos dentro do EasyPanel. Não é necessário no backend web principal.
MANALOOM_OPS_DATA_DIR=/data/manaloom-ops
MANALOOM_OPS_LOG_DIR=
MANALOOM_OPS_LOCK_DIR=
MANALOOM_OPS_ARTIFACT_DIR=
MANALOOM_RUN_PREFLIGHT_ON_BOOT=0
MANALOOM_AI_RUNTIME_CLEANUP_CRON=10 4 * * *
PULL_LEARNING_EVENTS_CRON=*/30 * * * *
AUTO_SYNC_LEARNED_DECKS_CRON=0 */2 * * *
MASTER_OPTIMIZER_PREFLIGHT_CRON=15 * * * *
MANALOOM_DART_BIN=dart
HERMES_KNOWLEDGE_DB=
MTGIA_ENV_FILE=
